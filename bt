#!/usr/bin/env python3
"""bt — Board Tool para agentes IT.

El directorio del board se determina así (en orden de prioridad):
  1. Variable de entorno IT_BOARD_DIR
  2. Directorio real donde vive este script
"""

import os, re, json, subprocess, sys
from datetime import datetime
from pathlib import Path

SCRIPT_DIR    = Path(__file__).resolve().parent
BOARD_DIR     = Path(os.environ.get("IT_BOARD_DIR", str(SCRIPT_DIR))).expanduser().resolve()
BOARD_FILE    = BOARD_DIR / "board.md"
TASKS_DIR     = BOARD_DIR / "tasks"
REVISAR_DIR   = BOARD_DIR / "para-revisar"
MANIFEST_FILE = REVISAR_DIR / "manifest.json"
WINDOWS_FILE  = BOARD_DIR / "windows.json"
TMUX_SESSION  = os.environ.get("IT_TMUX_SESSION", "bt-agents")

BOARD_TEMPLATE = """# Board — IT Agents

> Fuente de verdad del trabajo activo. Leer antes de empezar cualquier tarea.

## Activas

| ID | Tarea | Owner | Estado | Actividad | Actualizado |
|----|-------|-------|--------|-----------|-------------|
| — | — | — | — | — | — |

## En revisión / Bloqueadas

| ID | Tarea | Owner | Bloqueador | Actualizado |
|----|-------|-------|------------|-------------|
| — | — | — | — | — |

## Completadas

| ID | Tarea | Owner | Resultado breve | Fecha |
|----|-------|-------|-----------------|-------|
| — | — | — | — | — |
"""

# ── utils ─────────────────────────────────────────────────────────────────────

def today(): return datetime.now().strftime("%Y-%m-%d")
def now():   return datetime.now().strftime("%Y-%m-%d %H:%M")

def slugify(text):
    t = text.lower()
    for src, dst in [("áàäâ","a"),("éèëê","e"),("íìïî","i"),("óòöô","o"),("úùüû","u"),("ñ","n")]:
        for c in src: t = t.replace(c, dst)
    t = re.sub(r'[^a-z0-9\s-]', '', t)
    t = re.sub(r'\s+', '-', t.strip())
    return t[:40].rstrip('-')

def make_id(title):
    return f"task-{datetime.now().strftime('%Y%m%d')}-{slugify(title)}"

def resolve_id(partial):
    matches = [f.stem for f in TASKS_DIR.glob("task-*.md") if partial in f.stem]
    if len(matches) == 1:
        return matches[0]
    if len(matches) > 1:
        exact = [m for m in matches if m == partial]
        if exact: return exact[0]
        print(f"Ambiguo — posibles matches:\n  " + "\n  ".join(matches))
        return None
    if partial.startswith("task-"):
        return partial
    print(f"No encontrado: {partial}")
    return None

def normalize_task_id(task_id):
    if not task_id:
        return None
    return resolve_id(task_id)

def read_windows():
    try:
        if WINDOWS_FILE.exists():
            return json.loads(WINDOWS_FILE.read_text())
    except Exception:
        pass
    return {}

def write_windows(data):
    WINDOWS_FILE.write_text(json.dumps(data, ensure_ascii=False, indent=2) + "\n")

def ensure_board_layout():
    BOARD_DIR.mkdir(parents=True, exist_ok=True)
    TASKS_DIR.mkdir(parents=True, exist_ok=True)
    REVISAR_DIR.mkdir(parents=True, exist_ok=True)
    if not BOARD_FILE.exists():
        BOARD_FILE.write_text(BOARD_TEMPLATE)
    if not WINDOWS_FILE.exists():
        WINDOWS_FILE.write_text("{}\n")
    if not MANIFEST_FILE.exists():
        MANIFEST_FILE.write_text('{"items":[]}\n')

# ── board: manipulación de tablas markdown ────────────────────────────────────

S_ACTIVAS     = "Activas"
S_BLOQUEADAS  = "En revisión / Bloqueadas"
S_COMPLETADAS = "Completadas"

def trow(cols):
    return "| " + " | ".join(str(c) for c in cols) + " |"

def parse_row(line):
    return [c.strip() for c in line.split("|")[1:-1]]

def is_placeholder(line):
    return all(c in ("—","") or c.startswith("(vacío)") for c in parse_row(line))

def find_section(lines, name):
    for i, l in enumerate(lines):
        if re.match(r'^## ', l) and name.split()[0].lower() in l.lower():
            return i
    return None

def section_bounds(lines, sec_idx):
    nxt = next((i for i in range(sec_idx+1, len(lines)) if re.match(r'^## ', lines[i])), len(lines))
    header = sep = first = None
    for i in range(sec_idx+1, nxt):
        if lines[i].strip().startswith('|'):
            if   header is None: header = i
            elif sep    is None: sep    = i
            elif first  is None: first  = i; break
    return header, sep, first, nxt

def add_row(lines, section, cols):
    si = find_section(lines, section)
    if si is None: return lines
    header, sep, first, end = section_bounds(lines, si)
    if header is None: return lines
    drop = {i for i in range(si+1, end) if lines[i].strip().startswith('|') and is_placeholder(lines[i])}
    lines = [l for i,l in enumerate(lines) if i not in drop]
    si = find_section(lines, section)
    header, sep, first, end = section_bounds(lines, si)
    at = first if first is not None else (sep+1 if sep is not None else end)
    lines.insert(at, trow(cols))
    return lines

def remove_row(lines, tid):
    for i, l in enumerate(lines):
        if l.strip().startswith('|') and tid in l:
            cols = parse_row(l)
            sec  = next((re.match(r'^## (.+)', lines[j]).group(1).strip()
                         for j in range(i,-1,-1) if re.match(r'^## ', lines[j])), None)
            nl = lines[:i] + lines[i+1:]
            nl = restore_placeholder(nl, sec)
            return nl, cols, sec
    return lines, None, None

def restore_placeholder(lines, sec_name):
    if not sec_name: return lines
    si = find_section(lines, sec_name)
    if si is None: return lines
    header, sep, first, end = section_bounds(lines, si)
    if header is None: return lines
    data = [l for l in lines[(sep+1 if sep else header+1):end]
            if l.strip().startswith('|') and not is_placeholder(l)]
    if not data:
        hcols = parse_row(lines[header])
        lines.insert((sep+1 if sep is not None else header+1), trow(["—"]*len(hcols)))
    return lines

def update_row_cols(lines, tid, updates):
    for i, l in enumerate(lines):
        if not l.strip().startswith('|') or tid not in l: continue
        header_idx = None
        for j in range(i-1, -1, -1):
            if lines[j].strip().startswith('|') and re.match(r'^\|[-| ]+\|$', lines[j].strip()):
                header_idx = j - 1
                break
        headers = parse_row(lines[header_idx]) if header_idx is not None and header_idx >= 0 else []
        cols = parse_row(l)
        for key, val in updates.items():
            if isinstance(key, int):
                if key < len(cols): cols[key] = val
            else:
                idx = next((k for k,h in enumerate(headers) if key in h.lower()), None)
                if idx is not None and idx < len(cols): cols[idx] = val
        lines[i] = trow(cols)
        break
    return lines

def update_status_in_board(lines, tid, status):
    return update_row_cols(lines, tid, {"estado": status, "actualizado": today()})

# ── task files ────────────────────────────────────────────────────────────────

def create_task_file(tid, title, owner="claude", priority="medium", workspace="", desc=""):
    TASKS_DIR.mkdir(parents=True, exist_ok=True)
    path = TASKS_DIR / f"{tid}.md"
    ws_line = f"Workspace: {workspace}\n" if workspace else ""
    input_section = desc if desc else title
    path.write_text(f"""# {tid} — {title}

Owner: {owner}
Status: pending
Priority: {priority}
Date: {today()}
{ws_line}
## Qué se pide
{input_section}

## Cómo hacerlo
1. Paso 1
2. Paso 2
3. Validar

## Progreso
- {now()} — tarea creada

## Bloqueadores
ninguno

## Resultado
(completar al cerrar)
""")
    return path

def task_set_field(tid, field, value):
    path = TASKS_DIR / f"{tid}.md"
    if not path.exists(): return
    content = re.sub(rf'^{field}: .+$', f'{field}: {value}', path.read_text(), flags=re.MULTILINE)
    path.write_text(content)

def task_append_progress(tid, message):
    path = TASKS_DIR / f"{tid}.md"
    if not path.exists(): print(f"No encontrado: {tid}"); return
    lines = path.read_text().splitlines()
    entry, in_p, at = f"- {now()} — {message}", False, None
    for i, l in enumerate(lines):
        if l.startswith("## Progreso"): in_p = True
        elif in_p and l.startswith("## "): at = i; break
    if at: lines.insert(at, entry)
    else:  lines.append(entry)
    path.write_text("\n".join(lines) + "\n")

def task_set_result(tid, result):
    path = TASKS_DIR / f"{tid}.md"
    if not path.exists(): return
    content = re.sub(r'## Resultado\n.*', f'## Resultado\n{result}',
                     path.read_text(), flags=re.DOTALL)
    path.write_text(content.rstrip() + '\n')

def task_set_blocker(tid, reason):
    path = TASKS_DIR / f"{tid}.md"
    if not path.exists(): return
    content = path.read_text().replace("## Bloqueadores\nninguno",
                                       f"## Bloqueadores\n{reason}")
    path.write_text(content)

# ── comandos ──────────────────────────────────────────────────────────────────

def cmd_new(args):
    if not args: return print("Uso: bt new \"titulo\" [--owner nombre] [--priority media] [--workspace ws] [--desc \"descripcion completa\"]")
    title, owner, priority, workspace, desc = args[0], "claude", "medium", "", ""
    i = 1
    while i < len(args):
        if args[i] == "--owner"     and i+1 < len(args): owner     = args[i+1]; i += 2
        elif args[i] == "--priority" and i+1 < len(args): priority = args[i+1]; i += 2
        elif args[i] == "--workspace" and i+1 < len(args): workspace = args[i+1]; i += 2
        elif args[i] == "--desc"     and i+1 < len(args): desc      = args[i+1]; i += 2
        else: i += 1

    ensure_board_layout()
    tid = make_id(title)
    create_task_file(tid, title, owner, priority, workspace, desc)
    lines = BOARD_FILE.read_text().splitlines()
    lines = add_row(lines, S_ACTIVAS, [tid, title, owner, "pending", "", today()])
    BOARD_FILE.write_text("\n".join(lines) + "\n")
    print(f"✓ creada: {tid}")

def cmd_start(args):
    if not args: return print("Uso: bt start <id>")
    if not (tid := resolve_id(args[0])): return
    task_set_field(tid, "Status", "in_progress")
    lines = BOARD_FILE.read_text().splitlines()
    # Detectar si la tarea está en la sección Bloqueadas/Revisión y moverla a Activas
    in_blocked = False
    for i, l in enumerate(lines):
        if l.strip().startswith('|') and tid in l:
            for j in range(i-1, -1, -1):
                m = re.match(r'^## (.+)', lines[j])
                if m:
                    sec = m.group(1).strip()
                    if "bloqueada" in sec.lower() or "revisión" in sec.lower() or "revision" in sec.lower():
                        in_blocked = True
                    break
            break
    if in_blocked:
        lines, old, _ = remove_row(lines, tid)
        title = old[1] if old and len(old) > 1 else tid
        owner = old[2] if old and len(old) > 2 else "—"
        lines = add_row(lines, S_ACTIVAS, [tid, title, owner, "in_progress", "retomando...", today()])
    else:
        lines = update_row_cols(lines, tid,
                                {"estado": "in_progress", "actividad": "iniciando...", "actualizado": today()})
    BOARD_FILE.write_text("\n".join(lines) + "\n")
    print(f"✓ {tid} → in_progress")

def cmd_log(args):
    if len(args) < 2: return print("Uso: bt log <id> \"mensaje\"")
    if not (tid := resolve_id(args[0])): return
    msg = " ".join(args[1:])
    task_append_progress(tid, msg)
    task_set_field(tid, "Status", "in_progress")
    lines = BOARD_FILE.read_text().splitlines()
    # Si la tarea está en Bloqueadas, moverla a Activas al retomar trabajo
    in_blocked = False
    for i, l in enumerate(lines):
        if l.strip().startswith('|') and tid in l:
            for j in range(i-1, -1, -1):
                m = re.match(r'^## (.+)', lines[j])
                if m:
                    sec = m.group(1).strip()
                    if "bloqueada" in sec.lower() or "revisión" in sec.lower() or "revision" in sec.lower():
                        in_blocked = True
                    break
            break
    if in_blocked:
        lines, old, _ = remove_row(lines, tid)
        title = old[1] if old and len(old) > 1 else tid
        owner = old[2] if old and len(old) > 2 else "—"
        lines = add_row(lines, S_ACTIVAS, [tid, title, owner, "in_progress", msg[:200], today()])
    else:
        lines = update_row_cols(lines, tid, {"actividad": msg[:200], "actualizado": today()})
    BOARD_FILE.write_text("\n".join(lines) + "\n")
    print(f"✓ {tid}")

def cmd_block(args):
    if len(args) < 2: return print("Uso: bt block <id> \"razon\"")
    if not (tid := resolve_id(args[0])): return
    reason = " ".join(args[1:])
    task_set_field(tid, "Status", "blocked")
    task_set_blocker(tid, reason)
    lines = BOARD_FILE.read_text().splitlines()
    lines, old, _ = remove_row(lines, tid)
    if old:
        lines = add_row(lines, S_BLOQUEADAS, [tid, old[1] if len(old)>1 else tid,
                                              old[2] if len(old)>2 else "—", reason, today()])
    BOARD_FILE.write_text("\n".join(lines) + "\n")
    print(f"✓ {tid} → bloqueada: {reason}")

def _finalize_task(tid, result):
    """Ejecuta el cierre real de la tarea (mover a Completadas, limpiar, cerrar tmux)."""
    task_set_field(tid, "Status", "done")
    # Limpiar PendingResult si existe
    path = TASKS_DIR / f"{tid}.md"
    if path.exists():
        content = path.read_text()
        content = re.sub(r'^PendingResult: .+\n', '', content, flags=re.MULTILINE)
        path.write_text(content)
    task_append_progress(tid, f"completada — {result}")
    task_set_result(tid, result)
    lines = BOARD_FILE.read_text().splitlines()
    lines, old, _ = remove_row(lines, tid)
    if old:
        lines = add_row(lines, S_COMPLETADAS, [tid, old[1] if len(old)>1 else tid,
                                               old[2] if len(old)>2 else "—",
                                               result[:200], today()])
    BOARD_FILE.write_text("\n".join(lines) + "\n")
    print(f"✓ {tid} → done")

    # Limpiar para-revisar vinculados a esta tarea
    try:
        if MANIFEST_FILE.exists():
            manifest = json.loads(MANIFEST_FILE.read_text())
            linked = [
                i for i in manifest.get("items", [])
                if normalize_task_id(i.get("task_id")) == tid
            ]
            if linked:
                for item in linked:
                    f = REVISAR_DIR / item["file"]
                    if f.exists():
                        f.unlink()
                manifest["items"] = [
                    i for i in manifest["items"]
                    if normalize_task_id(i.get("task_id")) != tid
                ]
                MANIFEST_FILE.write_text(json.dumps(manifest, ensure_ascii=False, indent=2) + "\n")
                print(f"  → {len(linked)} item(s) de para-revisar eliminados")
    except Exception:
        pass

    # Cerrar ventana tmux si está trackeada
    try:
        windows = read_windows()
        slug = windows.pop(tid, None)
        if slug:
            subprocess.run(
                ["tmux", "kill-window", "-t", f"{TMUX_SESSION}:{slug}"],
                capture_output=True
            )
            write_windows(windows)
    except Exception:
        pass

def cmd_done(args):
    """bt done <id> "resultado" — solicita cierre (requiere confirmación del usuario)."""
    if len(args) < 2: return print("Uso: bt done <id> \"resultado\"")
    if not (tid := resolve_id(args[0])): return
    result = " ".join(args[1:])

    # Guardar resultado propuesto en el archivo de tarea
    path = TASKS_DIR / f"{tid}.md"
    if path.exists():
        content = path.read_text()
        # Reemplazar o insertar PendingResult después de la primera línea de metadatos
        if re.search(r'^PendingResult: ', content, re.MULTILINE):
            content = re.sub(r'^PendingResult: .+$', f'PendingResult: {result}', content, flags=re.MULTILINE)
        else:
            # Insertar después de la última línea de metadatos (antes de la primera sección ##)
            content = re.sub(r'(Date: .+\n)', rf'\1PendingResult: {result}\n', content, count=1)
            if f'PendingResult: {result}' not in content:
                # fallback: insertar después de la primera línea
                lines_c = content.splitlines()
                lines_c.insert(1, f'PendingResult: {result}')
                content = "\n".join(lines_c) + "\n"
        path.write_text(content)

    task_append_progress(tid, f"resultado propuesto: {result}")
    blocker = f"esperando aprobación: cerrar — {result[:180]}"
    task_set_field(tid, "Status", "blocked")
    task_set_blocker(tid, blocker)
    lines = BOARD_FILE.read_text().splitlines()
    lines, old, _ = remove_row(lines, tid)
    if old:
        lines = add_row(lines, S_BLOQUEADAS, [tid, old[1] if len(old)>1 else tid,
                                              old[2] if len(old)>2 else "—", blocker, today()])
    BOARD_FILE.write_text("\n".join(lines) + "\n")
    print(f"✓ {tid} → esperando aprobación para cerrar")
    print(f"  Resultado: {result}")
    print(f"  → El usuario aprueba (✓) en el board — el cierre es automático, no se requiere acción del agente.")

def cmd_finalize(args):
    """bt finalize <id> — cierra la tarea definitivamente (ejecutar tras aprobación del usuario)."""
    if not args: return print("Uso: bt finalize <id>")
    if not (tid := resolve_id(args[0])): return

    # Leer resultado pendiente del archivo de tarea
    path = TASKS_DIR / f"{tid}.md"
    result = ""
    if path.exists():
        for line in path.read_text().splitlines():
            if line.startswith("PendingResult: "):
                result = line[len("PendingResult: "):].strip()
                break

    if not result:
        # Permitir pasar resultado directo como argumento
        if len(args) > 1:
            result = " ".join(args[1:])
        else:
            print(f"No hay resultado pendiente para {tid}.")
            print("Usa: bt finalize <id> \"resultado\" para forzar cierre.")
            return

    _finalize_task(tid, result)

def cmd_revisar(args):
    if len(args) < 2:
        return print('Uso: bt revisar <ruta-o-nombre> "titulo" ["nota"] [--task <id>]')
    src = Path(args[0])
    title = args[1]
    note = ""
    task_id = None
    i = 2
    while i < len(args):
        if args[i] == "--task" and i+1 < len(args):
            task_id = args[i+1]; i += 2
        else:
            if not note: note = args[i]
            i += 1
    if task_id:
        task_id = normalize_task_id(task_id)
        if not task_id:
            return
    dest_name = src.name
    dest = REVISAR_DIR / dest_name
    if src.resolve() != dest.resolve():
        import shutil
        shutil.copy2(src, dest)
    manifest = {"items": []}
    if MANIFEST_FILE.exists():
        try: manifest = json.loads(MANIFEST_FILE.read_text())
        except Exception: pass
    manifest["items"] = [i for i in manifest.get("items", []) if i.get("file") != dest_name]
    entry = {
        "file": dest_name,
        "title": title,
        "date": today(),
        "note": note,
        "reviewed": False,
    }
    if task_id:
        entry["task_id"] = task_id
    manifest["items"].insert(0, entry)
    MANIFEST_FILE.write_text(json.dumps(manifest, ensure_ascii=False, indent=2) + "\n")
    print(f"✓ {dest_name} → para-revisar/")

def cmd_ls(args):
    """bt ls [status] — lista tareas; sin argumento muestra activas+bloqueadas"""
    if not TASKS_DIR.exists():
        print("No hay tareas."); return

    # Aliases de estado
    STATUS_ALIASES = {
        "active": ["pending", "in_progress"],
        "activas": ["pending", "in_progress"],
        "pending": ["pending"],
        "in_progress": ["in_progress"],
        "blocked": ["blocked"],
        "bloqueadas": ["blocked"],
        "done": ["done"],
        "completadas": ["done"],
        "all": ["pending", "in_progress", "blocked", "done"],
        "todas": ["pending", "in_progress", "blocked", "done"],
    }
    filter_arg = args[0].lower() if args else None
    if filter_arg and filter_arg not in STATUS_ALIASES:
        print(f"Estado desconocido: {filter_arg}")
        print(f"Opciones: {', '.join(STATUS_ALIASES)}")
        return
    filter_statuses = STATUS_ALIASES[filter_arg] if filter_arg else ["pending", "in_progress", "blocked"]

    STATUS_LABEL = {
        "pending":     "pending  ",
        "in_progress": "activa   ",
        "blocked":     "bloqueada",
        "done":        "done     ",
    }
    COLOR = {
        "pending":     "\033[33m",   # amarillo
        "in_progress": "\033[32m",   # verde
        "blocked":     "\033[31m",   # rojo
        "done":        "\033[90m",   # gris
    }
    RESET = "\033[0m"

    tasks = []
    for f in sorted(TASKS_DIR.glob("task-*.md")):
        content = f.read_text()
        status = "pending"
        owner  = "—"
        date   = "—"
        title  = f.stem
        for line in content.splitlines():
            if line.startswith("Status: "):   status = line[8:].strip()
            elif line.startswith("Owner: "):  owner  = line[7:].strip()
            elif line.startswith("Date: "):   date   = line[6:].strip()
            elif line.startswith("# ") and " — " in line:
                title = line.split(" — ", 1)[1].strip()
        if status in filter_statuses:
            tasks.append((date, f.stem, title, status, owner))

    if not tasks:
        label = filter_arg or "activas/bloqueadas"
        print(f"No hay tareas {label}."); return

    tasks.sort(key=lambda x: x[0], reverse=True)
    label = filter_arg or "activas + bloqueadas"
    print(f"\nTareas ({label}):\n")
    for date, tid, title, status, owner in tasks:
        col   = COLOR.get(status, "")
        slabel = STATUS_LABEL.get(status, status.ljust(9))
        short = tid.replace("task-", "")
        print(f"  {col}{slabel}{RESET}  {short}  {owner:<8}  {title[:60]}")
    print()

def cmd_status(args):
    """bt status — muestra resumen del board"""
    ensure_board_layout()
    lines = BOARD_FILE.read_text().splitlines()
    in_sec = None
    counts = {}
    for l in lines:
        m = re.match(r'^## (.+)', l)
        if m: in_sec = m.group(1).strip(); counts[in_sec] = 0
        elif in_sec and l.strip().startswith('|') and not re.match(r'^\|[-| ]+\|$', l.strip()):
            row = [c.strip() for c in l.split('|')[1:-1]]
            if row and not all(c in ('—','') for c in row):
                counts[in_sec] = counts.get(in_sec, 0) + 1
    for sec, n in counts.items():
        print(f"  {sec}: {n}")
    print(f"  Board: {BOARD_FILE}")

def cmd_show(args):
    """bt show <id> — muestra el archivo markdown de una tarea"""
    if not args: return print("Uso: bt show <id>")
    if not (tid := resolve_id(args[0])): return
    path = TASKS_DIR / f"{tid}.md"
    if not path.exists():
        print(f"No encontrado: {tid}")
        return
    print(path.read_text(), end="")

def cmd_serve(args):
    """bt serve — levanta el servidor HTTP del board"""
    import socket, signal
    server = BOARD_DIR / "server.py"
    if not server.exists():
        print(f"No se encontró server.py en {BOARD_DIR}")
        return
    port = int(os.environ.get("PORT", 8765))
    restart = False
    i = 0
    while i < len(args):
        if args[i] in ("--port", "-p") and i+1 < len(args):
            port = int(args[i+1]); i += 2
        elif args[i] in ("--restart", "-r"):
            restart = True; i += 1
        else:
            i += 1

    # Detectar si ya hay algo corriendo en el puerto
    with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
        in_use = s.connect_ex(("127.0.0.1", port)) == 0

    if in_use:
        if restart:
            # Matar proceso que ocupa el puerto
            try:
                r = subprocess.run(
                    ["lsof", "-ti", f":{port}"],
                    capture_output=True, text=True
                )
                pids = r.stdout.strip().split()
                for pid in pids:
                    try:
                        os.kill(int(pid), signal.SIGTERM)
                    except Exception:
                        pass
                import time; time.sleep(1)
                print(f"  Servidor anterior detenido.")
            except Exception as e:
                print(f"  No se pudo detener el servidor anterior: {e}")
                return
        else:
            print(f"El servidor ya está corriendo en http://localhost:{port}/board.html")
            print(f"  Usa 'bt serve --restart' para reiniciarlo.")
            return

    env = {**os.environ, "IT_BOARD_DIR": str(BOARD_DIR), "PORT": str(port)}
    try:
        subprocess.run([sys.executable, str(server)], env=env)
    except KeyboardInterrupt:
        pass

